<%- include("partials/header", { title: title }) %>

<main>

  <h1>Add New Project</h1>

  <form action="/new-project" method="POST">

    <div class="form-group">

      <label for="title">
        Project Title
      </label>

      <input
        type="text"
        id="title"
        name="title"
        required
        maxlength="200"
      />

    </div>

    <div class="form-group">

      <label for="description">
        Description
      </label>

      <textarea
        id="description"
        name="description"
        required
        maxlength="1000"
      ></textarea>

    </div>

    <div class="form-group">

      <label for="location">
        Location
      </label>

      <input
        type="text"
        id="location"
        name="location"
        required
        maxlength="200"
      />

    </div>

    <div class="form-group">

      <label for="date">
        Date
      </label>

      <input
        type="date"
        id="date"
        name="date"
        required
      />

    </div>

    <div class="form-group">

      <label for="organizationId">
        Organization
      </label>

      <select
        id="organizationId"
        name="organizationId"
        required
      >

        <option value="">
          Select Organization
        </option>

        <% organizations.forEach(organization => { %>

          <option
            value="<%= organization.organization_id %>"
          >
            <%= organization.name %>
          </option>

        <% }) %>

      </select>

    </div>

    <button type="submit">
      Create Project
    </button>

  </form>

</main>

<%- include("partials/footer") %>