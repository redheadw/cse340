<%- include("partials/header", { title: title }) %>

<main>
  <h2>Registered Users</h2>

  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email / Username</th>
        <th>Role</th>
      </tr>
    </thead>

    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.role_name %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>

<%- include("partials/footer") %>