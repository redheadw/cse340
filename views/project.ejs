<h2><%= project.title %></h2>

<p><%= project.description %></p>

<p>
  <strong>Date:</strong>
  <%= new Date(project.date).toLocaleDateString() %>
</p>

<p>
  <strong>Location:</strong>
  <%= project.location %>
</p>

<h3>Categories</h3>

<div class="tag-list">
  <% categories.forEach(category => { %>
    <a class="tag" href="/category/<%= category.category_id %>">
      <%= category.name %>
    </a>
  <% }) %>
</div>

<p>
  <a href="/project/<%= project.project_id %>/assign-categories">
    Edit Categories
  </a>
</p>