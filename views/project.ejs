<%- include("partials/header", { title: title }) %>

<main>
  <section class="card">
    <h2><%= project.title %></h2>

    <p><%= project.description %></p>

    <p>
      <strong>Date:</strong>
      <%= new Date(project.date).toLocaleDateString() %>
    </p>

    <p>
      <strong>Location:</strong>
      <%= project.location %>
    </p>

    <p>
      <strong>Partner Organization:</strong>
      <a href="/organization/<%= project.organization_id %>">
        <%= project.organization_name %>
      </a>
    </p>

    <h3>Categories</h3>

    <div class="tag-list">
      <% categories.forEach(category => { %>
        <a class="tag" href="/category/<%= category.category_id %>">
          <%= category.name %>
        </a>
      <% }) %>
    </div>

    <% if (user && user.role_name === "admin") { %>
      <p>
        <a href="/edit-project/<%= project.project_id %>">
          Edit Project
        </a>
      </p>

      <p>
        <a href="/project/<%= project.project_id %>/assign-categories">
          Edit Project Categories
        </a>
      </p>
    <% } %>

    <% if (isLoggedIn) { %>
      <% if (isVolunteering) { %>
        <p>
          You are volunteering for this project.
        </p>

        <p>
          <a href="/project/<%= project.project_id %>/remove-volunteer">
            Remove Myself as Volunteer
          </a>
        </p>
      <% } else { %>
        <p>
          <a href="/project/<%= project.project_id %>/volunteer">
            Volunteer for This Project
          </a>
        </p>
      <% } %>
    <% } %>

    <p>
      <a href="/projects">Back to Upcoming Projects</a>
    </p>
  </section>
</main>

<%- include("partials/footer") %>