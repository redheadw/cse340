<%- include("partials/header", { title: title }) %>

<main>
  <h2>Upcoming Service Projects</h2>

  <section class="card">
    <h3>Salsa Garden Kit Project</h3>

    <p>
      This project teaches how to grow a salsa garden kit using recycled
      materials. It includes recycling, planting, harvesting, and preserving
      salsa garden ingredients such as tomatoes, jalapeños, onions, and
      cilantro.
    </p>
  </section>

  <% if (user && user.role_name === "admin") { %>
    <p>
      <a href="/new-project">Add New Project</a>
    </p>
  <% } %>

  <section class="project-grid">
    <% projects.forEach(project => { %>
      <article class="card">
        <a href="/project/<%= project.project_id %>">
          <h3><%= project.title %></h3>
        </a>

        <p><%= project.description %></p>

        <p>
          <strong>Date:</strong>
          <%= new Date(project.date).toLocaleDateString() %>
        </p>

        <p>
          <strong>Location:</strong>
          <%= project.location %>
        </p>
      </article>
    <% }) %>
  </section>
</main>

<%- include("partials/footer") %>