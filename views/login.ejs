<%- include("partials/header", { title: title }) %>

<main>

  <h2>Login</h2>

  <form
    action="/login"
    method="POST"
    class="form-card"
  >

    <label for="email">
      Email
    </label>

    <input
      type="email"
      id="email"
      name="email"
      required
    >

    <label for="password">
      Password
    </label>

    <input
      type="password"
      id="password"
      name="password"
      required
    >

    <button type="submit">
      Login
    </button>

  </form>

</main>

<%- include("partials/footer") %>